{
  "name": "ecom-lens-pro",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Internal E-commerce Asset Extractor",
  "author": "Internal Team",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@google/genai": "latest",
    "clsx": "^2.1.0",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.internal.ecomlens",
    "productName": "E-Com Lens Pro",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir"
    }
  }
}
